{
    "editor.fontFamily": "Fira Code, Menlo, Monaco, 'Courier New', monospace",
    "editor.fontSize": 18,
    "editor.fontLigatures": true,
    "workbench.colorTheme": "Monokai",
    "files.trimTrailingWhitespace": true,
    "files.insertFinalNewline": true,
    "files.trimFinalNewlines": true,
    "breadcrumbs.enabled": true,
    "editor.tabSize": 2,
    "ruby.lint": {
        "rubocop": true
    },
    "solargraph.diagnostics": true,
    "dupchecker.leaveEmptyLine": false,
    "emmet.triggerExpansionOnTab": true,
    "telemetry.enableCrashReporter": false,
    "telemetry.enableTelemetry": false,
    "extensions.ignoreRecommendations": false,
    "ruby.rubocop.suppressRubocopWarnings": false,
    "editor.formatOnPaste": false,
    "editor.formatOnType": false,
    "[javascript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "ruby.rubocop.useBundler": true,
    "editor.formatOnSave": false,
    "yaml.maxItemsComputed": 0,
    "redhat.telemetry.enabled": true,
    "editor.accessibilitySupport": "off",
    "vscode-yaml-sort.quotingType": "\"",
    "vscode-yaml-sort.useLeadingDashes": false,
    "workbench.sideBar.location": "right",
    "discord.removeRemoteRepository": true,
    "discord.removeDetails": true,
    "[html]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "editor.multiCursorLimit": 20000,
    "security.workspace.trust.untrustedFiles": "open",
    "tailwindCSS.experimental.classRegex": [
        "\\bclass:\\s*'([^']*)'",
        "\\bclass:\\s*\"([^\"]*)\""
    ],
    "[json]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "discord.removeLowerDetails": true,
    "discord.swapBigAndSmallImage": true,
    "window.zoomLevel": 2,
    "editor.stickyScroll.enabled": true
}
